{% set prevDraft = pager.prevHref and (collections.project | isDraft(pager.prevHref | replace(".html",""))) %}
{% set nextDraft = pager.nextHref and (collections.project | isDraft(pager.nextHref | replace(".html",""))) %}
<div class="pager wrap"{% if track == "industrial" %} style="border-top-color:var(--dark-hair)"{% endif %}>
  {% if pager.prevHref %}<a href="/projects/{{ pager.prevHref }}"><span class="dir">Previous {% if track == "industrial" %}project{% else %}case study{% endif %}</span>← {{ pager.prevTitle }}{% if prevDraft %}<span class="pager-tag">In progress</span>{% endif %}</a>{% else %}<span></span>{% endif %}
  {% if pager.nextHref %}<a href="/projects/{{ pager.nextHref }}"><span class="dir">Next {% if track == "industrial" %}project{% else %}case study{% endif %}</span>{{ pager.nextTitle }} →{% if nextDraft %}<span class="pager-tag">In progress</span>{% endif %}</a>{% else %}<span></span>{% endif %}
</div>
